{
    "name": "ghanem/multiple-date-picker",
    "description": "A Laravel Nova field for selecting multiple dates with a beautiful date picker interface.",
    "keywords": [
        "laravel",
        "nova",
        "date-picker",
        "multiple-dates",
        "field"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/nova": "^4.0|^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ghanem\\MultipleDatePicker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghanem\\MultipleDatePicker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ghanem\\MultipleDatePicker\\FieldServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
